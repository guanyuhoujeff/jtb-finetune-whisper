# ============================================
# JTB Finetune Whisper - 環境設定
# ============================================
# 複製此檔案為 .env 並修改設定值

# ============================================
# 🖥️ 前端設定 (Frontend)
# ============================================
# 網頁服務 Port
FRONTEND_PORT=42040
# 後端 API 位址 (必須是瀏覽器可存取的位址)
# 如果在本機執行，通常設為 http://localhost:42045/api
VITE_API_BASE_URL=http://localhost:42045/api

# ============================================
# ⚙️ 後端設定 (Backend)
# ============================================
# 後端服務 Port
SERVER_PORT=42045
SERVER_HOST=0.0.0.0

# 後端 API Key (必填)
# 客戶端必須在 HTTP header 帶 `x-api-key: <此值>` 才能存取 /api/*。
# 建議使用 `python -c "import secrets; print(secrets.token_urlsafe(32))"` 產生。
BACKEND_API_KEY=
# 允許的瀏覽器來源，逗號分隔。Production 切勿使用 *。
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 後端 log level (DEBUG / INFO / WARNING / ERROR)
BACKEND_LOG_LEVEL=INFO
# 僅供本機臨時開發使用：設為 1 時才允許在沒有 API Key 的情況下啟動。
# 任何上線環境都不可開啟此選項。
BACKEND_ALLOW_INSECURE_NO_AUTH=0

# ============================================
# 📦 MinIO 設定 (Storage)
# ============================================
# 請務必修改為強密碼，至少 12 個字元並包含大小寫、數字、符號。
# MinIO 啟動時會直接使用這組憑證作為 root 帳號，請勿留空或使用預設值上線。
MINIO_USER=
MINIO_PASSWORD=
# API Port (預設 9000)
MINIO_API_PORT=9000
# Console Port (預設 9001)
MINIO_CONSOLE_PORT=9001
# 後端連接 MinIO 的位址 (Docker 內部通常用服務名稱 minio:9000)
MINIO_ENDPOINT=minio:9000
# MinIO 資料儲存路徑
# 預設使用 Docker Volume (minio-data)，若要存儲在當前目錄下的 minio_data 資料夾：
# MINIO_DATA_PATH=./minio_data
MINIO_DATA_PATH=minio-data

# ============================================
# 📊 監控工具
# ============================================
# TensorBoard Port
TENSORBOARD_PORT=6006
# JupyterLab Port
JUPYTER_PORT=28888

# ============================================
# 🏗️ Docker Build 設定
# ============================================
# CUDA 版本 (需配合 NVIDIA Driver)
CUDA_VER=12.8
CUDNN_VER=9
